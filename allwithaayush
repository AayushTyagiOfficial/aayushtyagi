<script>
// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
const ADMIN_EMAIL = 'aayushtyagi511@gmail.com';
const ADMIN_PASS  = 'aayush2098';

let currentUser = JSON.parse(localStorage.getItem('awa_user') || 'null');
let products     = JSON.parse(localStorage.getItem('awa_products') || '[]');
let cart         = JSON.parse(localStorage.getItem('awa_cart') || '[]');
let wishlist     = JSON.parse(localStorage.getItem('awa_wishlist') || '[]');
let users        = JSON.parse(localStorage.getItem('awa_users') || '[]');
let activeFilter = 'All';
let currentPage  = 'home';

// ══════════════════════════════════════════════════════
// SAVE
// ══════════════════════════════════════════════════════
const save = () => {
  localStorage.setItem('awa_products', JSON.stringify(products));
  localStorage.setItem('awa_cart', JSON.stringify(cart));
  localStorage.setItem('awa_wishlist', JSON.stringify(wishlist));
  localStorage.setItem('awa_users', JSON.stringify(users));
  if(currentUser) localStorage.setItem('awa_user', JSON.stringify(currentUser));
  else localStorage.removeItem('awa_user');
};

// ══════════════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════════════
let toastTimer;
function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.className = 'toast', 3000);
}

// ══════════════════════════════════════════════════════
// AUTH
// ══════════════════════════════════════════════════════
function switchAuthTab(tab) {
  document.querySelectorAll('.auth-tab').forEach((t,i) => {
    t.classList.toggle('active', (i===0&&tab==='login')||(i===1&&tab==='signup'));
  });
  document.getElementById('login-form').classList.toggle('active', tab==='login');
  document.getElementById('signup-form').classList.toggle('active', tab==='signup');
}

function handleLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass  = document.getElementById('login-password').value;
  const err   = document.getElementById('login-error');
  if(!email||!pass){err.style.display='block';err.textContent='Please fill in all fields.';return;}
  // Admin check
  if(email===ADMIN_EMAIL && pass===ADMIN_PASS){
    loginUser({email,name:'Aayush',isAdmin:true});return;
  }
  // Regular user
  const u = users.find(u=>u.email===email&&u.pass===pass);
  if(!u){err.style.display='block';err.textContent='Invalid email or password.';return;}
  loginUser(u);
}

function handleSignup() {
  const name  = document.getElementById('signup-name').value.trim();
  const email = document.getElementById('signup-email').value.trim();
  const pass  = document.getElementById('signup-password').value;
  const err   = document.getElementById('signup-error');
  if(!name||!email||!pass){err.style.display='block';err.textContent='Please fill in all fields.';return;}
  if(pass.length<6){err.style.display='block';err.textContent='Password must be at least 6 characters.';return;}
  if(users.find(u=>u.email===email)){err.style.display='block';err.textContent='Email already registered.';return;}
  const u = {email,name,pass,isAdmin:false};
  users.push(u); save();
  loginUser(u);
}

function handleGoogleLogin() {
  // Simulate Google login with a mock user
  const mockEmail = 'student@gmail.com';
  let u = users.find(u=>u.email===mockEmail);
  if(!u){ u={email:mockEmail,name:'Google User',pass:'',isAdmin:false}; users.push(u); save(); }
  loginUser(u);
}

function loginUser(u) {
  currentUser = u;
  save();
  document.getElementById('auth-overlay').classList.add('hidden');
  updateNav();
  showToast('Welcome, ' + u.name + '! 👋', 'success');
}

function handleLogout() {
  currentUser = null;
  save();
  document.getElementById('auth-overlay').classList.remove('hidden');
  updateNav();
  closeUserMenu();
  goPage('home');
}

// ══════════════════════════════════════════════════════
// NAV
// ══════════════════════════════════════════════════════
function updateNav() {
  if(!currentUser) return;
  document.getElementById('nav-avatar').textContent = currentUser.name[0].toUpperCase();
  document.getElementById('nav-user-name').textContent = currentUser.name.split(' ')[0];
  document.getElementById('admin-link').style.display = currentUser.isAdmin ? 'flex' : 'none';
  updateBadges();
}

function updateBadges() {
  const cc = document.getElementById('cart-count');
  const wc = document.getElementById('wishlist-count');
  cc.textContent = cart.length; cc.style.display = cart.length ? 'flex' : 'none';
  wc.textContent = wishlist.length; wc.style.display = wishlist.length ? 'flex' : 'none';
}

function toggleUserMenu() {
  document.getElementById('user-dropdown').classList.toggle('open');
}
function closeUserMenu() {
  document.getElementById('user-dropdown').classList.remove('open');
}
document.addEventListener('click', e => {
  if(!document.getElementById('nav-user-btn').contains(e.target))
    closeUserMenu();
});

// ══════════════════════════════════════════════════════
// ROUTING
// ══════════════════════════════════════════════════════
function goPage(p) {
  if(!currentUser && p !== 'home') { showToast('Please sign in first.'); return; }
  if(p === 'admin' && (!currentUser || !currentUser.isAdmin)) {
    showToast('Admin access only.', 'error'); return;
  }
  document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  document.querySelectorAll('.nav-link').forEach(l => {
    l.classList.toggle('active', l.textContent.toLowerCase().includes(p) || (p==='home'&&l.textContent==='Home'));
  });
  currentPage = p;
  window.scrollTo(0,0);
  if(p==='shop') renderShop();
  if(p==='admin') renderAdmin();
}

function filterAndGoShop(cat) {
  activeFilter = cat;
  goPage('shop');
  document.querySelectorAll('.filter-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.cat===cat);
  });
}

// ══════════════════════════════════════════════════════
// SHOP
// ══════════════════════════════════════════════════════
function setFilter(cat) {
  activeFilter = cat;
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.toggle('active', t.dataset.cat===cat));
  renderShop();
}

function renderShop() {
  const q = (document.getElementById('shop-search')?.value||'').toLowerCase();
  let list = products;
  if(activeFilter !== 'All') list = list.filter(p=>p.category===activeFilter);
  if(q) list = list.filter(p=>p.name.toLowerCase().includes(q)||p.description.toLowerCase().includes(q)||p.category.toLowerCase().includes(q));
  const grid = document.getElementById('products-grid');
  if(!list.length){
    grid.innerHTML = `<div class="no-products" style="grid-column:1/-1"><h3>No products found</h3><p>${products.length===0?'The shop is being stocked. Check back soon!':'Try a different search or category.'}</p></div>`;
    return;
  }
  grid.innerHTML = list.map(p => productCardHTML(p)).join('');
}

function productCardHTML(p) {
  const inWish = wishlist.includes(p.id);
  return `
  <div class="product-card">
    <div class="product-img-wrap">
      ${p.image ? `<img class="product-img" src="${p.image}" alt="${p.name}">` : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:40px;background:var(--accent-light)">${getCatEmoji(p.category)}</div>`}
      <div class="product-badge">${p.category}</div>
      <button class="product-wishlist-btn ${inWish?'active':''}" onclick="toggleWishlist('${p.id}',event)" title="${inWish?'Remove from wishlist':'Add to wishlist'}">
        <svg width="14" height="14" fill="${inWish?'currentColor':'none'}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
    </div>
    <div class="product-body">
      <div class="product-category">${p.category}</div>
      <div class="product-name">${p.name}</div>
      <div class="product-desc">${p.description}</div>
      <div class="product-footer">
        <div class="product-price">₹${p.price} <span>one-time</span></div>
        <div class="product-actions">
          <button class="btn-add-cart" onclick="addToCart('${p.id}')">+ Cart</button>
          <button class="btn-buy" onclick="window.open('${p.link}','_blank')">Buy Now</button>
        </div>
      </div>
    </div>
  </div>`;
}

function getCatEmoji(cat) {
  const m = {Planners:'📅',Templates:'🎨','AI Study Goodies':'🤖','Booster Packs':'⚡',Stickers:'🌸','Cheat Sheets':'📝',Flashcards:'🃏'};
  return m[cat]||'📦';
}

// ══════════════════════════════════════════════════════
// CART
// ══════════════════════════════════════════════════════
function addToCart(id) {
  if(!cart.includes(id)){ cart.push(id); save(); updateBadges(); showToast('Added to cart! 🛒','success'); }
  else showToast('Already in cart!');
}
function removeFromCart(id) { cart = cart.filter(c=>c!==id); save(); updateBadges(); renderCart(); }
function openCart()  { document.getElementById('cart-panel').classList.add('open'); document.getElementById('cart-overlay').classList.add('open'); renderCart(); }
function closeCart() { document.getElementById('cart-panel').classList.remove('open'); document.getElementById('cart-overlay').classList.remove('open'); }

function renderCart() {
  const body = document.getElementById('cart-body');
  const footer = document.getElementById('cart-footer');
  if(!cart.length){
    body.innerHTML = `<div class="empty-state"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg><h4>Your cart is empty</h4><p>Browse the shop and add some products!</p></div>`;
    footer.innerHTML = '';
    return;
  }
  const items = cart.map(id=>products.find(p=>p.id===id)).filter(Boolean);
  const total = items.reduce((s,p)=>s+Number(p.price),0);
  body.innerHTML = items.map(p=>`
  <div class="cart-item">
    ${p.image?`<img class="cart-item-img" src="${p.image}" alt="${p.name}">`:`<div class="cart-item-img" style="display:flex;align-items:center;justify-content:center;font-size:28px">${getCatEmoji(p.category)}</div>`}
    <div class="cart-item-info">
      <div class="cart-item-name">${p.name}</div>
      <div class="cart-item-price">₹${p.price}</div>
      <div style="font-size:12px;color:var(--text3);margin-top:2px">${p.category}</div>
    </div>
    <button class="cart-item-remove" onclick="removeFromCart('${p.id}')">✕</button>
  </div>`).join('');
  footer.innerHTML = `
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
    <span style="font-size:14px;color:var(--text2)">Total (${items.length} item${items.length>1?'s':''})</span>
    <span style="font-size:20px;font-weight:800;color:var(--accent)">₹${total}</span>
  </div>
  <p style="font-size:12px;color:var(--text3);margin-bottom:14px">⚠️ No refunds on digital products. Each item has its own Buy Now link.</p>
  <div style="display:flex;flex-direction:column;gap:8px">
    ${items.map(p=>`<button class="btn-buy" style="width:100%" onclick="window.open('${p.link}','_blank')">Buy Now: ${p.name}</button>`).join('')}
  </div>`;
}

// ══════════════════════════════════════════════════════
// WISHLIST
// ══════════════════════════════════════════════════════
function toggleWishlist(id, e) {
  e?.stopPropagation();
  if(wishlist.includes(id)){ wishlist=wishlist.filter(w=>w!==id); showToast('Removed from wishlist'); }
  else { wishlist.push(id); showToast('Added to wishlist ♥'); }
  save(); updateBadges();
  if(currentPage==='shop') renderShop();
  renderWishlist();
}
function openWishlist()  { document.getElementById('wishlist-panel').classList.add('open'); document.getElementById('wishlist-overlay').classList.add('open'); renderWishlist(); }
function closeWishlist() { document.getElementById('wishlist-panel').classList.remove('open'); document.getElementById('wishlist-overlay').classList.remove('open'); }

function renderWishlist() {
  const body = document.getElementById('wishlist-body');
  const items = wishlist.map(id=>products.find(p=>p.id===id)).filter(Boolean);
  if(!items.length){
    body.innerHTML = `<div class="empty-state"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><h4>Your wishlist is empty</h4><p>Heart products you love to save them here!</p></div>`;
    return;
  }
  body.innerHTML = items.map(p=>`
  <div class="wishlist-item">
    ${p.image?`<img class="wishlist-item-img" src="${p.image}" alt="${p.name}">`:`<div class="wishlist-item-img" style="display:flex;align-items:center;justify-content:center;font-size:24px">${getCatEmoji(p.category)}</div>`}
    <div class="wishlist-item-info">
      <div class="wishlist-item-name">${p.name}</div>
      <div class="wishlist-item-price">₹${p.price}</div>
    </div>
    <div class="wishlist-item-actions">
      <button class="btn-add-cart" onclick="addToCart('${p.id}')">+ Cart</button>
      <button class="cart-item-remove" onclick="toggleWishlist('${p.id}')">✕</button>
    </div>
  </div>`).join('');
}

// ══════════════════════════════════════════════════════
// ADMIN
// ══════════════════════════════════════════════════════
function switchAdminTab(tab) {
  document.querySelectorAll('.admin-tab-content').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  document.querySelectorAll('.sidebar-item').forEach((s,i)=>{
    const tabs = ['dashboard','analytics','add-product','manage-products'];
    s.classList.toggle('active', tabs.indexOf(tab)!==-1 && s.textContent.trim().toLowerCase().replace(' ','').includes(tab.replace('-','')));
  });
  document.querySelectorAll('.sidebar-item').forEach(s=>{
    const map = {dashboard:'Dashboard',analytics:'Analytics','add-product':'Add Product','manage-products':'Manage Products'};
    s.classList.toggle('active', s.textContent.trim()===map[tab]);
  });
  if(tab==='analytics') renderAnalytics();
  if(tab==='manage-products') renderAdminProducts();
}

function renderAdmin() {
  updateDashboardStats();
  renderAdminRecentProducts();
}

function updateDashboardStats() {
  const total = products.reduce((s,p)=>s+Number(p.price),0);
  const cats = [...new Set(products.map(p=>p.category))];
  document.getElementById('stat-products').textContent = products.length;
  document.getElementById('stat-cats').textContent = cats.length;
  document.getElementById('stat-value').textContent = '₹'+total;
  document.getElementById('stat-avg').textContent = products.length ? '₹'+Math.round(total/products.length) : '₹0';
}

function renderAdminRecentProducts() {
  const el = document.getElementById('recent-products-list');
  const recent = [...products].reverse().slice(0,5);
  if(!recent.length){ el.textContent='No products yet. Add your first product!'; return; }
  el.innerHTML = recent.map(p=>`
  <div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)">
    ${p.image?`<img src="${p.image}" style="width:44px;height:44px;border-radius:8px;object-fit:cover">`:`<div style="width:44px;height:44px;border-radius:8px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;font-size:20px">${getCatEmoji(p.category)}</div>`}
    <div style="flex:1">
      <div style="font-size:14px;font-weight:600">${p.name}</div>
      <div style="font-size:12px;color:var(--text2)">${p.category}</div>
    </div>
    <div style="font-size:16px;font-weight:700;color:var(--accent)">₹${p.price}</div>
  </div>`).join('');
}

function renderAnalytics() {
  const total = products.reduce((s,p)=>s+Number(p.price),0);
  const cats = [...new Set(products.map(p=>p.category))];
  document.getElementById('a-stat-products').textContent = products.length;
  document.getElementById('a-stat-cats').textContent = cats.length;
  document.getElementById('a-stat-value').textContent = '₹'+total;
  document.getElementById('a-stat-avg').textContent = products.length ? '₹'+Math.round(total/products.length) : '₹0';

  // Bar chart
  const chart = document.getElementById('cat-bar-chart');
  if(!products.length){ chart.innerHTML='<p style="color:var(--text3);font-size:14px;margin:auto">Add products to see analytics</p>'; return; }
  const catCounts = {};
  products.forEach(p=>{ catCounts[p.category]=(catCounts[p.category]||0)+1; });
  const max = Math.max(...Object.values(catCounts));
  chart.innerHTML = Object.entries(catCounts).map(([cat,count])=>`
  <div class="bar-wrap">
    <span style="font-size:11px;color:var(--accent);font-weight:700">${count}</span>
    <div class="bar" style="height:${(count/max)*120}px;background:var(--accent)"></div>
    <span>${cat.split(' ')[0]}</span>
  </div>`).join('');

  // Price dist
  const pd = document.getElementById('price-dist');
  if(!products.length){ pd.textContent='Add products to see price insights.'; return; }
  const prices = products.map(p=>Number(p.price));
  pd.innerHTML = `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:4px">
    <div class="stat-card"><div class="label">Min Price</div><div class="value">₹${Math.min(...prices)}</div></div>
    <div class="stat-card"><div class="label">Max Price</div><div class="value">₹${Math.max(...prices)}</div></div>
    <div class="stat-card"><div class="label">Avg Price</div><div class="value">₹${Math.round(prices.reduce((a,b)=>a+b)/prices.length)}</div></div>
  </div>`;
}

function renderAdminProducts() {
  const el = document.getElementById('admin-products-container');
  if(!products.length){ el.innerHTML='<div class="admin-card"><p style="color:var(--text2);font-size:14px">No products yet. Go to "Add Product" to list your first product!</p></div>'; return; }
  el.innerHTML = `<div class="admin-products-list">${products.map(p=>`
  <div class="admin-product-card">
    ${p.image?`<img src="${p.image}" alt="${p.name}">`:`<div style="width:100%;height:160px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;font-size:40px">${getCatEmoji(p.category)}</div>`}
    <div class="body">
      <div class="cat">${p.category}</div>
      <h4>${p.name}</h4>
      <div class="price">₹${p.price}</div>
      <div class="actions">
        <button class="btn-danger" onclick="deleteProduct('${p.id}')">Delete</button>
        <a href="${p.link}" target="_blank" style="padding:10px 14px;background:var(--accent-light);color:var(--accent);border-radius:8px;font-size:13px;font-weight:600">View Link</a>
      </div>
    </div>
  </div>`).join('')}</div>`;
}

function previewImage(input) {
  if(input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      const prev = document.getElementById('img-preview');
      prev.src = e.target.result;
      prev.style.display = 'block';
    };
    reader.readAsDataURL(input.files[0]);
  }
}

function addProduct() {
  const name = document.getElementById('p-name').value.trim();
  const cat  = document.getElementById('p-cat').value;
  const price= document.getElementById('p-price').value;
  const link = document.getElementById('p-link').value.trim();
  const desc = document.getElementById('p-desc').value.trim();
  const imgInput = document.getElementById('p-img');

  if(!name||!cat||!price||!link||!desc){ showToast('Please fill in all required fields.','error'); return; }

  const id = 'p_' + Date.now();
  const imgSrc = document.getElementById('img-preview').src || '';

  products.push({ id, name, category:cat, price:Number(price), link, description:desc, image: imgSrc.startsWith('data')?imgSrc:'' });
  save();
  showToast('Product listed successfully! ✅', 'success');
  clearProductForm();
  updateDashboardStats();
  renderAdminRecentProducts();
}

function clearProductForm() {
  ['p-name','p-price','p-link','p-desc'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('p-cat').value='';
  document.getElementById('p-img').value='';
  document.getElementById('img-preview').style.display='none';
  document.getElementById('img-preview').src='';
}

function deleteProduct(id) {
  if(!confirm('Are you sure you want to delete this product? This cannot be undone.')) return;
  products = products.filter(p=>p.id!==id);
  cart = cart.filter(c=>c!==id);
  wishlist = wishlist.filter(w=>w!==id);
  save(); showToast('Product deleted.'); renderAdminProducts(); updateDashboardStats(); renderAdminRecentProducts();
}

// ══════════════════════════════════════════════════════
// CONTACT
// ══════════════════════════════════════════════════════
function sendContactForm() {
  const n=document.getElementById('c-name').value.trim();
  const e=document.getElementById('c-email').value.trim();
  const s=document.getElementById('c-subject').value.trim();
  const m=document.getElementById('c-message').value.trim();
  if(!n||!e||!s||!m){ showToast('Please fill in all fields.','error'); return; }
  showToast('Message sent! We\'ll reply soon ✉️','success');
  ['c-name','c-email','c-subject','c-message'].forEach(id=>document.getElementById(id).value='');
}

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
if(currentUser) {
  document.getElementById('auth-overlay').classList.add('hidden');
  updateNav();
} else {
  document.getElementById('auth-overlay').classList.remove('hidden');
}
updateBadges();
</script>
